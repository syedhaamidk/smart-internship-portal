# ─────────────────────────────────────────
# Smart Internship Portal — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=internship_portal

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Groq API  →  https://console.groq.com/keys
# Sign up free, create an API key, paste it below
# Free tier: ~14,400 requests/day, no credit card needed
GROQ_API_KEY=your_groq_api_key_here

# Adzuna Job API (https://developer.adzuna.com/)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=in

# Email (Nodemailer — use Gmail or SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password       # Gmail App Password (not login password)
EMAIL_FROM="Smart Internship Portal <noreply@internshipportal.com>"

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880              # 5MB in bytes

# Frontend URL (for CORS)
FRONTEND_URL=http://127.0.0.1:5500
